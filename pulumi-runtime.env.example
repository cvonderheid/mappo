# MAPPO Pulumi runtime stack inputs.
# Copy to .data/pulumi-runtime.env and fill runtime-only values.
# Platform stack, subscription, location, and Pulumi passphrase are read from
# .data/pulumi-platform.env by scripts/source_runtime_deploy_env.sh.
# Do not commit filled values.

export MAPPO_PULUMI_STACK_KIND="runtime"
export MAPPO_MARKETPLACE_INGEST_TOKEN=""
export MAPPO_BACKEND_CUSTOM_DOMAIN=""
export MAPPO_FRONTEND_CUSTOM_DOMAIN=""
export MAPPO_FRONTEND_DNS_ZONE_NAME=""
export MAPPO_FRONTEND_DNS_ZONE_RESOURCE_GROUP=""
export MAPPO_BACKEND_CUSTOM_DOMAIN_CERTIFICATE_ENABLED="false"
export MAPPO_FRONTEND_CUSTOM_DOMAIN_CERTIFICATE_ENABLED="false"
