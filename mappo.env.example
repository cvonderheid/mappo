# MAPPO consolidated environment template.
# Copy to .data/mappo.env for local/demo use, fill in values, then source it before running scripts:
#   set -a
#   source .data/mappo.env
#   set +a
#
# This file documents every runtime/deploy secret MAPPO needs. Do not commit filled values.

# -----------------------------------------------------------------------------
# Local runtime defaults
# -----------------------------------------------------------------------------
# Docker Compose works without changing these defaults.
export MAPPO_JDBC_DATABASE_URL="jdbc:postgresql://localhost:5433/mappo"
export MAPPO_DB_HOST="localhost"
export MAPPO_DB_PORT="5433"
export MAPPO_DB_NAME="mappo"
export MAPPO_DB_USER="mappo"
export MAPPO_DB_PASSWORD="mappo"
export MAPPO_DB_SSLMODE="disable"
export MAPPO_BACKEND_PORT="8010"
export MAPPO_CORS_ORIGINS="http://localhost:5174,http://127.0.0.1:5174"
export MAPPO_REDIS_ENABLED="true"
export MAPPO_REDIS_HOST="localhost"
export MAPPO_REDIS_PORT="6380"
export MAPPO_REDIS_PASSWORD=""
export MAPPO_REDIS_SSL_ENABLED="false"

# -----------------------------------------------------------------------------
# Azure artifact publishing and Pulumi
# -----------------------------------------------------------------------------
# Required for direct infra/pulumi operations. Maven publishes images only; it
# does not run Pulumi or mutate Azure infrastructure.
export PULUMI_CONFIG_PASSPHRASE=""
export AZURE_SUBSCRIPTION_ID=""
export MAPPO_RUNTIME_ENABLED="true"
export MAPPO_RUNTIME_APPS_ENABLED="false"  # Set true after Maven publishes images to the Pulumi-created ACR.
export MAPPO_RUNTIME_SUBSCRIPTION_ID=""
export MAPPO_RUNTIME_RESOURCE_GROUP=""
export MAPPO_RUNTIME_LOCATION="centralus"
export MAPPO_RUNTIME_IMAGE_TAG=""          # Usually the Maven image tag output: <pom-version>-<git-sha>.
export MAPPO_IMAGE_PREFIX=""               # Required by ./mvnw deploy. Example: <pulumi-acr>.azurecr.io
export MAPPO_DOCKER_USERNAME=""            # Usually the Pulumi-created ACR username.
export MAPPO_DOCKER_PASSWORD=""            # Usually the Pulumi-created ACR password.

# Managed Postgres is owned by Pulumi. Leave the password blank unless you need
# to import/reuse a known password; Pulumi generates one for fresh stacks.
export MAPPO_CONTROL_PLANE_DB_ENABLED="true"
export MAPPO_CONTROL_PLANE_SUBSCRIPTION_ID=""
export MAPPO_CONTROL_PLANE_DB_ADMIN_PASSWORD=""

# -----------------------------------------------------------------------------
# MAPPO Azure SDK identity
# -----------------------------------------------------------------------------
# Used by MAPPO direct Azure deployment paths and target/runtime Azure validation.
export MAPPO_AZURE_TENANT_ID=""
export MAPPO_AZURE_CLIENT_ID=""
export MAPPO_AZURE_CLIENT_SECRET=""
# Optional Entra object id to receive Key Vault secret permissions alongside
# the MAPPO runtime managed identity.
export MAPPO_AZURE_KEY_VAULT_ACCESS_OBJECT_ID=""
# JSON map of subscription id -> tenant id for cross-tenant target subscriptions.
export MAPPO_AZURE_TENANT_BY_SUBSCRIPTION="{}"

# -----------------------------------------------------------------------------
# MAPPO runtime ingress and target registration
# -----------------------------------------------------------------------------
# Token used by marketplace/registration ingest endpoints when enabled.
export MAPPO_MARKETPLACE_INGEST_TOKEN=""
# Set from Pulumi outputs after runtime apps are enabled.
export MAPPO_API_BASE_URL=""
export MAPPO_RUNTIME_BACKEND_URL=""
export MAPPO_RUNTIME_FRONTEND_URL=""

# -----------------------------------------------------------------------------
# Azure Key Vault secret references
# -----------------------------------------------------------------------------
# Hosted MAPPO should resolve external-provider credentials from this Key Vault.
# Admin -> Secret Inventory should reference secret names only, not secret values.
export MAPPO_AZURE_KEY_VAULT_URL=""
export MAPPO_AZURE_KEY_VAULT_NAME=""

# -----------------------------------------------------------------------------
# GitHub release source credentials
# -----------------------------------------------------------------------------
# Webhook secret verifies inbound GitHub release-source events.
# GitHub token is only needed when MAPPO/scripts read repository contents or create demo hooks.
export MAPPO_MANAGED_APP_RELEASE_REPO=""
export MAPPO_MANAGED_APP_RELEASE_PATH="releases/releases.manifest.json"
export MAPPO_MANAGED_APP_RELEASE_REF="main"
export MAPPO_MANAGED_APP_RELEASE_WEBHOOK_SECRET=""
export MAPPO_MANAGED_APP_RELEASE_GITHUB_TOKEN=""
export GITHUB_TOKEN=""

# -----------------------------------------------------------------------------
# Azure DevOps release source and deployment connection credentials
# -----------------------------------------------------------------------------
# AZURE_DEVOPS_EXT_PAT is used by setup/demo scripts.
# MAPPO_AZURE_DEVOPS_PERSONAL_ACCESS_TOKEN is the backend default deployment connection PAT.
export AZURE_DEVOPS_EXT_PAT=""
export MAPPO_AZURE_DEVOPS_BASE_URL="https://dev.azure.com"
export MAPPO_AZURE_DEVOPS_PERSONAL_ACCESS_TOKEN=""
export MAPPO_AZURE_DEVOPS_WEBHOOK_SECRET=""
export MAPPO_AZURE_DEVOPS_API_VERSION="7.1"

# -----------------------------------------------------------------------------
# Publisher ACR / target image pull configuration
# -----------------------------------------------------------------------------
# Used by direct Azure rollout paths when target templates need image pull credentials.
export MAPPO_PUBLISHER_ACR_SERVER=""
export MAPPO_PUBLISHER_ACR_PULL_CLIENT_ID=""
export MAPPO_PUBLISHER_ACR_PULL_CLIENT_SECRET=""
export MAPPO_PUBLISHER_ACR_PULL_SECRET_NAME="publisher-acr-pull"
export MAPPO_PUBLISHER_ACR_TENANT_ID=""
export MAPPO_PUBLISHER_ACR_NAME=""
export MAPPO_PUBLISHER_ACR_ID=""

# -----------------------------------------------------------------------------
# Optional EasyAuth / Azure portal auth configuration.
# Hosted EasyAuth app registration and redirect URIs are owned by Pulumi when
# MAPPO_RUNTIME_APPS_ENABLED=true and MAPPO_EASYAUTH_ENABLED=true.
# -----------------------------------------------------------------------------
export MAPPO_EASYAUTH_ENABLED="true"

# -----------------------------------------------------------------------------
# Optional Partner Center helper scripts
# -----------------------------------------------------------------------------
export MAPPO_PARTNER_CENTER_ACCESS_TOKEN=""
export MAPPO_PARTNER_CENTER_TOKEN_EXPIRES_ON=""
