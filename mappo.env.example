# MAPPO local/demo environment template.
# Copy to .data/mappo.env for local runtime and demo scripts. Pulumi has its own
# templates: pulumi-platform.env.example and pulumi-runtime.env.example.
# Do not commit filled values.

# -----------------------------------------------------------------------------
# Local runtime defaults
# -----------------------------------------------------------------------------
# Docker Compose works without changing these defaults.
export MAPPO_JDBC_DATABASE_URL="jdbc:postgresql://localhost:5433/mappo"
export MAPPO_DB_HOST="localhost"
export MAPPO_DB_PORT="5433"
export MAPPO_DB_NAME="mappo"
export MAPPO_DB_USER="mappo"
export MAPPO_DB_PASSWORD="mappo"
export MAPPO_DB_SSLMODE="disable"
export MAPPO_BACKEND_PORT="8010"
export MAPPO_CORS_ORIGINS="http://localhost:5174,http://127.0.0.1:5174"
export MAPPO_REDIS_ENABLED="true"
export MAPPO_REDIS_HOST="localhost"
export MAPPO_REDIS_PORT="6380"
export MAPPO_REDIS_PASSWORD=""
export MAPPO_REDIS_SSL_ENABLED="false"

# -----------------------------------------------------------------------------
# Hosted runtime output
# -----------------------------------------------------------------------------
# Set this from the runtime Pulumi output when running demo/helper scripts
# against a hosted MAPPO backend.
export MAPPO_API_BASE_URL=""

# -----------------------------------------------------------------------------
# Demo/release helper scripts
# -----------------------------------------------------------------------------
export MAPPO_MARKETPLACE_INGEST_TOKEN=""
export MAPPO_MANAGED_APP_RELEASE_REPO=""
export MAPPO_MANAGED_APP_RELEASE_PATH="releases/releases.manifest.json"
export MAPPO_MANAGED_APP_RELEASE_REF="main"
export GITHUB_TOKEN=""
export AZURE_DEVOPS_EXT_PAT=""
export MAPPO_AZURE_DEVOPS_BASE_URL="https://dev.azure.com"
export MAPPO_AZURE_DEVOPS_API_VERSION="7.1"

# -----------------------------------------------------------------------------
# Optional Partner Center helper scripts
# -----------------------------------------------------------------------------
export MAPPO_PARTNER_CENTER_ACCESS_TOKEN=""
export MAPPO_PARTNER_CENTER_TOKEN_EXPIRES_ON=""
